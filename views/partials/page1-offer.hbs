{{! Page 1 – Οικονομική Προσφορά (offer list) }}

<section class="quotation-page quotation-page-1">
  {{! ----- Header: title left, umbrella icon right ----- }}
  <header class="quotation-header">
    <h1 class="quotation-title">{{title}}</h1>
    <img src="{{#if assets.headerIconUrl}}{{assets.headerIconUrl}}{{else}}/icons/umbrella.svg{{/if}}" alt=""
      class="header-icon">
  </header>

  {{#if isCatalogDesign}}
  {{! ----- Catalog layout for Design 2 ----- }}
  <section class="catalog-products-section">
    <div class="catalog-products-row">
      <span class="catalog-products-label">Προϊόν</span>
      <div class="contact-cell products-list">
        {{#each products}}
        <div class="product-block">
          <div class="product-row-inner">
            <div class="product-image-wrap">
              <img
                src="{{#if this.image_src}}{{this.image_src}}{{else}}{{#if ../assets.asideImageUrl}}{{../assets.asideImageUrl}}{{else}}/icons/umbrella-product-icon.svg{{/if}}{{/if}}"
                alt="" class="product-image">
            </div>
            <div class="product-body">
              <h3 class="product-name">{{this.title}}</h3>
              <p class="product-description">{{this.description}}</p>
              <div class="product-details-block">
                {{#each this.details}}
                <div class="product-detail-row">
                  <span class="product-dimensions">{{this.dimensions}}</span>
                  <span class="product-price">{{this.price}}</span>
                </div>
                {{/each}}
              </div>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{else}}
  {{! ----- Contact: labels left, details right (row per block) ----- }}
  <section class="quotation-contact">
    <h2 class="section-label">Στοιχεία Επικοινωνίας</h2>
    <div class="contact-row">
      <span class="contact-label">Από</span>
      <div class="contact-cell">
        <p class="contact-line">{{sender.name}}</p>
        <p class="contact-line contact-line-department">{{sender.department}}</p>
        <p class="contact-line">Τηλέφωνο: {{sender.phone}}</p>
      </div>
    </div>
    <div class="contact-row">
      <span class="contact-label">Προς</span>
      <div class="contact-cell">
        <p class="contact-line">{{recipient.name}}</p>
        <p class="contact-line">{{recipient.order_method}}</p>
        <p class="contact-line">{{recipient.vat_info}}</p>
      </div>
    </div>
    <div class="contact-row contact-row-products">
      <span class="contact-label">Προϊόν</span>
      <div class="contact-cell products-list">
        {{#each products}}
        <div class="product-block">
          <div class="product-row-inner">
            <div class="product-image-wrap">
              <img
                src="{{#if this.image_src}}{{this.image_src}}{{else}}{{#if ../assets.asideImageUrl}}{{../assets.asideImageUrl}}{{else}}/icons/umbrella-product-icon.svg{{/if}}{{/if}}"
                alt="" class="product-image">
            </div>
            <div class="product-body">
              <h3 class="product-name">{{this.title}}</h3>
              <p class="product-description">{{this.description}}</p>
              <div class="product-details-block">
                {{#each this.details}}
                {{#unless @first}}
                <hr class="detail-separator">{{/unless}}
                <div class="product-detail-row">
                  <span class="product-dimensions">{{this.dimensions}}</span>
                  <span class="product-price">{{this.price}}</span>
                </div>
                {{/each}}
              </div>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/if}}

  <div class="quotation-spacer"></div>
  {{! ----- Footer: website + email left, phones right ----- }}
  <footer class="quotation-footer">
    <div class="footer-left">
      <span class="footer-website">{{footer.website}}</span>
      <span class="footer-email">{{footer.email}}</span>
    </div>
    <div class="footer-right">
      <span class="footer-phone">{{footer.phone1}}</span>
      <span class="footer-phone">{{footer.phone2}}</span>
    </div>
  </footer>
</section>